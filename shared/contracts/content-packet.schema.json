{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContentPacket",
  "description": "Contrat d'interface entre Content Factory et Distribution Engine",
  "version": "1.0.0",
  "type": "object",
  "required": ["id", "type", "caption", "hashtags", "target_accounts", "scheduled_at", "niche", "status"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Identifiant unique du contenu"
    },
    "type": {
      "type": "string",
      "enum": ["post", "story", "reel", "carousel"],
      "description": "Type de contenu Instagram"
    },
    "caption": {
      "type": "string",
      "maxLength": 2200,
      "description": "Texte du post généré par IA"
    },
    "visual_url": {
      "type": "string",
      "format": "uri",
      "description": "URL du visuel généré (DALL-E / Stable Diffusion)"
    },
    "visual_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "URLs pour carousel (max 10)"
    },
    "hashtags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 30,
      "description": "Hashtags optimisés par niche"
    },
    "target_accounts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "IDs des comptes cibles dans Distribution Engine"
    },
    "scheduled_at": {
      "type": "string",
      "format": "date-time",
      "description": "Date/heure de publication souhaitée (ISO 8601)"
    },
    "niche": {
      "type": "string",
      "description": "Niche cible (ex: fitness, food, travel, business)"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "queued", "publishing", "published", "failed", "cancelled"],
      "default": "pending"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_by": { "type": "string" },
        "template_id": { "type": "string" },
        "language": { "type": "string", "default": "fr" },
        "campaign_id": { "type": "string" },
        "ab_variant": { "type": "string", "enum": ["A", "B"] }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
