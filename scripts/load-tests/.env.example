# Load Test Environment Configuration
# Copy this file to .env and adjust values for your environment

# Service URLs
BASE_URL_CONTENT_FACTORY=http://localhost:8000
BASE_URL_DISTRIBUTION=http://localhost:3001
REDIS_URL=redis://localhost:6379

# Authentication (get from running system)
AUTH_TOKEN=

# Test Configuration
NUM_ACCOUNTS=50

# Test Levels
# 50 = Baseline (stable)
# 200 = Stress (expected stable with minor issues)
# 500 = Limit (expected degradation)
