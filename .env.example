# Influence Platform — Environmental Variables Template

# --- DATABASE ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=influence_db

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- AI SERVICES (Content Factory) ---
# Caption / orchestration — required for generation to succeed:
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: legacy alias read by config if ANTHROPIC is unset
CLAUDE_API_KEY=
# Images/video (Kie) — optional; captions still work without it
KIE_API_KEY=
# Seedance / AILIVEAI (optional; Kie-style job API when using compatible base URL)
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://api.kie.ai
GENERATION_SEEDANCE_MAX_POLLS=144
AILIVEAI_API_KEY=
AILIVEAI_API_TOKEN=
AILIVEAI_MEDIA_ID=
# POST /prompts + /prompts/image-to-video → api.aliveai.app only (not api-server, or you get HTTP 405).
AILIVEAI_BASE_URL=https://api.aliveai.app
AILIVEAI_POLL_BASE_URL=https://api-server.aliveai.app
AILIVEAI_VIDEO_MODEL=SEEDANCE
# When AILIVEAI_API_TOKEN is set → always Bearer. When API key only in AILIVEAI_API_KEY: key|bearer|auto (auto: JWT→Bearer).
AILIVEAI_AUTH_MODE=auto
AILIVEAI_REQUEST_BLOCKING=false
GENERATION_AILIVEAI_MAX_POLLS=60
# Scene preview / some flows — optional
GEMINI_API_KEY=
OPENAI_API_KEY=sk-...

# --- INSTAGRAM / PROXIES ---
# (Usually managed via the dashboard accounts page, but can be set here for defaults)

# Content Factory: 0 = no uvicorn --reload (avoids ERR_EMPTY_RESPONSE on long/polling requests). 1 = hot-reload Python.
# UVICORN_RELOAD=0

# --- SECURITY ---
NEXTAUTH_SECRET=generate_a_random_string_here
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=another_random_string
# fleet = operators see all org data (default, V1); scoped = operators see assigned personas only
ACCESS_MODE=scoped
DEFAULT_ORGANIZATION_SLUG=influence
NEXT_PUBLIC_EMULATOR_CONTROLLER_URL=http://localhost:9102
# Dashboard: allow Reel in the Generation Studio publish block (set false to disable)
NEXT_PUBLIC_FEATURE_INSTAGRAM_REEL_PUBLISH_ENABLED=true
# Content Factory: allow Reel in publish-intent API (must be true for reel publishes to succeed)
FEATURE_INSTAGRAM_REEL_PUBLISH_ENABLED=true

# --- MONITORING ---
SENTRY_DSN=
ENVIRONMENT=production

# --- SETTINGS ---
# Distribution: skip real Instagram/Playwright when true. Keep false for production-real publishing.
PUBLISH_DRY_RUN=false
# Engagement (comment reply, DM, simulated comment like): defaults to PUBLISH_DRY_RUN when unset
ENGAGEMENT_DRY_RUN=true
# Distribution Engine proxy to Content Factory for /engagement/* routes
CONTENT_FACTORY_URL=http://content-factory:8000
# Allow comment_like stub without Graph API (internal testing only)
# ENGAGEMENT_ALLOW_COMMENT_LIKE_STUB=false
# Strict dynamic mode: disable synthetic preview fallbacks and demo scene caps in content-factory.
DYNAMIC_MODE_STRICT=true
GENERATION_ALLOW_SYNTHETIC_PREVIEW_FALLBACK=false
GENERATION_ENABLE_DEMO_CAPS=false
# Dev/demo: Studio button to seed /queue with a completed job (no Kie tokens). Also set NEXT_PUBLIC_* on dashboard.
GENERATION_ALLOW_QUEUE_SIMULATION=false
GENERATION_QUEUE_SIMULATION_VIDEO_URL=https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4
# Tests only: skip 200-500ms idempotency recheck before external publish (distribution-engine)
# PUBLISH_SKIP_RACE_RECHECK=true
MAX_CONCURRENT_WORKERS=3
CONTENT_QUEUE_NAME=content:ready
# Studio jobs: publish_intents (default) | legacy_queue (also push content:ready)
GENERATION_DISTRIBUTION_MODE=publish_intents
ALLOWED_ORIGINS=http://localhost:3000,https://app.yourdomain.com

# --- SMS PROVIDERS (Choose one or configure multiple for failover) ---
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# MessageBird (alternative)
MESSAGEBIRD_API_KEY=
MESSAGEBIRD_ORIGINATOR=

# Vonage/Nexmo (alternative)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# OTP Settings
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=60

# --- STRIPE BILLING ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
DEFAULT_DOMAIN=influenceplatform.io

# --- EMULATOR CONTROLLER ---
DISTRIBUTION_API_USERNAME=
DISTRIBUTION_API_PASSWORD=
PROXY_CREDENTIALS_KEY=
# V1: one dedicated proxy per persona (falls back to per-account during migration)
PROXY_STRICT_ONE_TO_ONE=true
# Route Graph API and outbound HTTP via persona proxy (distribution-engine)
USE_PERSONA_PROXY_FOR_GRAPH=true
PERSONA_ENFORCE_EGRESS=true
# When proxies use 127.0.0.1:port on the host, DE in Docker reaches them via this alias
PROXY_LOCAL_HOST_ALIAS=host.docker.internal
PERSONA_EGRESS_CHECK_URLS=https://api.ipify.org,https://ifconfig.me/ip
# Emulator: pair work by persona device binding, not zip(accounts, devices)
USE_PERSONA_ORCHESTRATION=true
CLAUDE_MODEL=claude-3-5-sonnet-20241022
APPIUM_SERVER_URL=http://host.docker.internal:4723
ANDROID_APP_PACKAGE=com.instagram.android
ANDROID_APP_ACTIVITY=com.instagram.mainactivity.LauncherActivity
ADB_PATH=adb
ADB_HOST=host.docker.internal
ADB_PORT=5037
# List/launch AVDs from the HOST (Docker has no Android SDK). See emulator-controller/host_agent/README.md
EMULATOR_AGENT_URL=http://host.docker.internal:19200
EMULATOR_AGENT_TOKEN=
# How long POST /emulators/add waits for ADB + boot (seconds). Lower = faster API, may return phase booting/pending.
EMULATOR_LAUNCH_WAIT_SECONDS=25
EMULATOR_BOOT_WAIT_SECONDS=12
# Optional on host when running host_agent (Windows: ...\Android\Sdk\emulator\emulator.exe)
# ANDROID_SDK_ROOT=C:\Users\YOU\AppData\Local\Android\Sdk
# EMULATOR_PATH=C:\Users\YOU\AppData\Local\Android\Sdk\emulator\emulator.exe
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=30
IDLE_POLL_INTERVAL_SECONDS=300
REQUEST_TIMEOUT_SECONDS=15
MAX_PARALLEL_EMULATORS=5
MIN_HUMAN_DELAY_SECONDS=1.2
MAX_HUMAN_DELAY_SECONDS=4.5
METRICS_PORT=9101
SCREENSHOT_SERVER_PORT=9102
SCREENSHOT_ONLY_IF_MISSING_AI=true
PROXY_BRIDGE_LISTEN_HOST=0.0.0.0
PROXY_BRIDGE_PUBLIC_HOST=10.0.2.2
PROXY_BRIDGE_PORT_START=19100
PROXY_BRIDGE_PORT_END=19199
DEFAULT_MAX_POSTS_PER_DAY=3
DEFAULT_MAX_LIKES_PER_HOUR=20
DEFAULT_MAX_FOLLOWS_PER_DAY=15
